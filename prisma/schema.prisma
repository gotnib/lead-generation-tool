generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id           String   @id @default(cuid())
  businessName String
  category     String
  city         String
  address      String?
  phone        String?
  website      String?
  rating       Float?
  reviewCount  Int?
  status       String   @default("new")
  notes        String?
  pitchEmail   String?
  contactName  String?
  contactEmail   String?
  hasUnreadReply Boolean  @default(false)
  emails         Email[]
  createdAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Email {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction String
  subject   String
  body      String
  fromAddr  String
  toAddr    String
  createdAt DateTime @default(now())
}
