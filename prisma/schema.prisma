generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  businessName String
  category    String
  city        String
  address     String?
  phone       String?
  website     String?
  rating      Float?
  reviewCount Int?
  status      String   @default("new")
  notes       String?
  pitchEmail  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
